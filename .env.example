# Copy to `.env` and fill in real values. Do not commit `.env`.

# ── Database (Neon Postgres) ─────────────────────────────────────────
# Pooled connection used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct (unpooled) connection used only by the Prisma CLI via prisma.config.ts.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ── Auth (NextAuth v5) ───────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret"
# GitHub OAuth app credentials.
AUTH_GITHUB_ID="your-github-oauth-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-client-secret"
# Base URL used to build absolute links in emails (and by Auth.js).
AUTH_URL="http://localhost:3000"

# ── Email (Resend) ───────────────────────────────────────────────────
# API key from https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key"
# Verification email sender. onboarding@resend.dev is Resend's shared test
# sender (delivers only to your Resend account email); swap for a verified domain.
EMAIL_FROM="DevStash <onboarding@resend.dev>"
# Email verification is ON by default. Set to "false" to disable it: no
# verification emails are sent and new accounts can sign in immediately.
# (Takes effect after a server restart.)
EMAIL_VERIFICATION_ENABLED="true"
